{
  "name": "devoxx2026-api-regression-demo",
  "version": "1.0.0",
  "description": "Demo project for Devoxx 2026 - E2E API testing generated by AI",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "volta": {
    "node": "22.15.0",
    "npm": "11.3.0"
  },
  "scripts": {
    "build": "wireit",
    "build:clinerules": "wireit",
    "build:transpile": "wireit",
    "clean": "wireit",
    "clean:all": "wireit",
    "clean:dist": "wireit",
    "clean:npm": "wireit",
    "clean:npm:cache": "wireit",
    "clean:ts": "wireit",
    "clean:wireit": "rimraf -v .wireit",
    "qa": "wireit",
    "qa:biome": "wireit",
    "qa:biome:fix": "wireit",
    "qa:fix": "wireit",
    "qa:markdown": "wireit",
    "qa:markdown:fix": "wireit",
    "slides:build": "wireit",
    "slides:serve": "wireit",
    "test": "wireit",
    "test:e2e": "wireit",
    "test:e2e:live": "wireit",
    "test:e2e:mock": "wireit",
    "test:e2e:step-by-step": "wireit",
    "validate": "wireit"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "axios": "1.15.0",
    "dotenv": "17.4.2",
    "jsonpath-plus": "10.4.0",
    "lodash": "4.18.1",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@jest/globals": "29.7.0",
    "@marp-team/marp-cli": "4.3.1",
    "@mermaid-js/mermaid-cli": "11.12.0",
    "@types/lodash": "4.17.24",
    "@types/node": "25.6.0",
    "jest": "29.7.0",
    "markdownlint-cli2": "0.22.0",
    "puppeteer": "24.40.0",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "wireit": "0.14.12"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "build:clinerules",
        "build:transpile"
      ]
    },
    "build:clinerules": {
      "command": "node scripts/build-clinerules.mjs",
      "files": [
        "prompts/**/*"
      ],
      "output": [
        ".clinerules/**/*"
      ]
    },
    "build:transpile": {
      "command": "tsc",
      "files": [
        "src/**/*.ts",
        "*.json"
      ],
      "output": [
        "lib/**"
      ],
      "clean": "if-file-deleted"
    },
    "clean": {
      "dependencies": [
        "clean:dist",
        "clean:ts"
      ]
    },
    "clean:all": {
      "dependencies": [
        "clean",
        "clean:npm",
        "clean:wireit"
      ]
    },
    "clean:dist": {
      "command": "rimraf -v dist"
    },
    "clean:npm": {
      "command": "rimraf -v node_modules package-lock.json",
      "dependencies": [
        "clean:npm:cache"
      ]
    },
    "clean:npm:cache": {
      "command": "rimraf -v -g '**/.npm'"
    },
    "clean:ts": {
      "command": "rimraf -v -g '**/*.tsbuildinfo'"
    },
    "qa": {
      "dependencies": [
        "qa:biome",
        "qa:markdown"
      ]
    },
    "qa:biome": {
      "command": "biome check src scripts *.json *.ts *.js",
      "files": [
        "src/**",
        "*.json",
        "*.ts",
        "*.js"
      ],
      "output": []
    },
    "qa:biome:fix": {
      "command": "biome check --fix src scripts *.json *.ts *.js",
      "files": [
        "src/**",
        "*.json",
        "*.ts",
        "*.js"
      ],
      "output": []
    },
    "qa:fix": {
      "dependencies": [
        "qa:biome:fix",
        "qa:markdown:fix"
      ]
    },
    "qa:markdown": {
      "command": "markdownlint-cli2",
      "files": [
        ".markdownlint-cli2.jsonc",
        "doc/**/*.md"
      ],
      "output": []
    },
    "qa:markdown:fix": {
      "command": "markdownlint-cli2 --fix",
      "files": [
        ".markdownlint-cli2.jsonc",
        "doc/**/*.md"
      ],
      "output": []
    },
    "slides:build": {
      "command": "marp slides/presentation.md -o dist/presentation.html --allow-local-files --no-stdin",
      "files": [
        "slides/**/*"
      ],
      "output": [
        "dist/presentation.html"
      ]
    },
    "slides:serve": {
      "command": "marp -s slides --allow-local-files",
      "files": [
        "slides/**/*"
      ]
    },
    "test": {
      "command": "MOCK=true jest",
      "files": [
        "src/**",
        "*.json",
        "*.ts",
        "*.yaml"
      ]
    },
    "test:e2e": {
      "command": "MOCK=true jest src/test/e2e/products-to-offers.e2e.test.ts",
      "files": [
        "src/**",
        "*.json",
        "*.ts",
        "*.yaml"
      ]
    },
    "test:e2e:live": {
      "command": "MOCK=false jest src/test/e2e/products-to-offers.e2e.test.ts",
      "files": [
        "src/**",
        "*.json",
        "*.ts",
        "*.yaml"
      ]
    },
    "test:e2e:mock": {
      "command": "MOCK=true jest src/test/e2e/products-to-offers.e2e.test.ts",
      "files": [
        "src/**",
        "*.json",
        "*.ts",
        "*.yaml"
      ]
    },
    "test:e2e:step-by-step": {
      "command": "MOCK=true jest src/test/e2e/products-to-offers.step-by-step.test.ts",
      "files": [
        "src/**",
        "*.json",
        "*.ts",
        "*.yaml"
      ]
    },
    "validate": {
      "dependencies": [
        "build",
        "qa",
        "test"
      ]
    }
  }
}
